generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  USER
}

enum Marketplace {
  OTTO
  AMAZON
  KAUFLAND
  MEDIAMARKT
  EBAY
  SHOPIFY
  DIREKT
}

enum ActivityType {
  SALE
  RECEIPT
  CORRECTION
  USER_CHANGE
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(USER)
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sales        Sale[]
  receipts     Receipt[]
  corrections  Correction[]
  activities   ActivityLog[]
  herdsetSales HerdsetSale[]
  invoices     Invoice[]
}


model Item {
  sku           String         @id
  name          String         @default("")
  stock         Int            @default(0)
  stockNS       Int            @default(0)
  minStock      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sales         Sale[]
  receipts      Receipt[]
  corrections   Correction[]
  activities    ActivityLog[]
  shipmentItems ShipmentItem[]
}

model Sale {
  id          String      @id @default(cuid())
  date        DateTime
  marketplace Marketplace
  sku         String
  quantity    Int
  source      String      @default("TAGESVERKAUF")
  userId      String
  createdAt   DateTime    @default(now())
  item        Item        @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([sku])
}

model Receipt {
  id        String   @id @default(cuid())
  date      DateTime
  sku       String
  quantity  Int
  userId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([sku])
}

model Correction {
  id        String   @id @default(cuid())
  date      DateTime
  sku       String
  quantity  Int
  reason    String
  userId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([sku])
}

model HerdsetSale {
  id          String      @id @default(cuid())
  date        DateTime
  marketplace Marketplace
  label       String
  quantity    Int
  userId      String
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])

  @@index([date])
}

model Invoice {
  id              String        @id @default(cuid())
  number          String        @unique
  date            DateTime
  customerName    String
  customerAddress String
  customerNum     String?
  mwstRate        Int           @default(19)
  shippingCost    Float?
  shippingMwst    Int           @default(19)
  paymentMethod   String        @default("konto")
  notes           String?
  paymentInfo     String?
  status             String        @default("aktiv")
  storniertAt        DateTime?
  docType            String        @default("rechnung")
  originalInvoiceId  String?
  originalInvoiceNum String?
  marketplace        String?
  createdAt          DateTime      @default(now())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  items           InvoiceItem[]

  @@index([date])
  @@index([number])
  @@index([status])
  @@index([docType])
}

model InvoiceItem {
  id          String           @id @default(cuid())
  invoiceId   String
  pos         Int
  quantity    Float
  description String
  unitPrice   Float
  invoice     Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  skus        InvoiceItemSku[]
}

model InvoiceItemSku {
  id            String      @id @default(cuid())
  invoiceItemId String
  sku           String
  lager         String      @default("neuware")
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
}

model Order {
  id             String      @id @default(cuid())
  externalId     String      @unique
  marketplace    String
  status         String      @default("NEU")
  customerName   String
  street         String
  zip            String
  city           String
  country        String      @default("DE")
  billingName    String?
  billingStreet  String?
  billingZip     String?
  billingCity    String?
  billingCountry String?
  phoneNumber    String?
  orderDate      DateTime
  orderNumber    String?
  trackingNumber String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
  shipments      Shipment[]

  @@index([status])
  @@index([marketplace])
  @@index([orderDate])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  marketplaceSku String
  internalSku    String?
  positionItemId String?
  title          String
  quantity       Int
  price          Float
}

model Shipment {
  id              String         @id @default(cuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id])
  carrier         String
  status          String         @default("LABEL_CREATED")
  trackingNumber       String?
  labelUrl             String?
  returnTrackingNumber String?
  returnLabelUrl       String?
  dhlShipmentId        String?
  weight          Float?
  carrierResponse Json?
  notifiedOttoAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           ShipmentItem[]

  @@index([orderId])
  @@index([status])
}

model ShipmentItem {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  internalSku String
  item        Item     @relation(fields: [internalSku], references: [sku])
  quantity    Int
  warehouse   String   @default("neuware")
  createdAt   DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  sku       String?
  oldStock  Int?
  newStock  Int?
  note      String?
  userId    String
  createdAt DateTime     @default(now())
  item      Item?        @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([type])
  @@index([sku])
}
