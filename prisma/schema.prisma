generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  USER
}

enum Marketplace {
  OTTO
  AMAZON
  KAUFLAND
  MEDIAMARKT
  EBAY
  SHOPIFY
  DIREKT
}

enum ActivityType {
  SALE
  RECEIPT
  CORRECTION
  USER_CHANGE
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(USER)
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sales        Sale[]
  receipts     Receipt[]
  corrections  Correction[]
  activities   ActivityLog[]
  herdsetSales HerdsetSale[]
  invoices     Invoice[]
}


model Item {
  sku          String         @id
  name         String         @default("")
  stock        Int            @default(0)
  stockNS      Int            @default(0)
  minStock     Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sales        Sale[]
  receipts     Receipt[]
  corrections  Correction[]
  activities   ActivityLog[]
}

model Sale {
  id          String      @id @default(cuid())
  date        DateTime
  marketplace Marketplace
  sku         String
  quantity    Int
  source      String      @default("TAGESVERKAUF")
  userId      String
  createdAt   DateTime    @default(now())
  item        Item        @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([sku])
}

model Receipt {
  id        String   @id @default(cuid())
  date      DateTime
  sku       String
  quantity  Int
  userId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([sku])
}

model Correction {
  id        String   @id @default(cuid())
  date      DateTime
  sku       String
  quantity  Int
  reason    String
  userId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([sku])
}

model HerdsetSale {
  id          String      @id @default(cuid())
  date        DateTime
  marketplace Marketplace
  label       String
  quantity    Int
  userId      String
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])

  @@index([date])
}

model Invoice {
  id              String        @id @default(cuid())
  number          String        @unique
  date            DateTime
  customerName    String
  customerAddress String
  customerNum     String?
  mwstRate        Int           @default(19)
  shippingCost    Float?
  paymentMethod   String        @default("konto")
  notes           String?
  paymentInfo     String?
  status          String        @default("aktiv")
  storniertAt     DateTime?
  createdAt       DateTime      @default(now())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  items           InvoiceItem[]

  @@index([date])
  @@index([number])
  @@index([status])
}

model InvoiceItem {
  id          String           @id @default(cuid())
  invoiceId   String
  pos         Int
  quantity    Float
  description String
  unitPrice   Float
  invoice     Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  skus        InvoiceItemSku[]
}

model InvoiceItemSku {
  id            String      @id @default(cuid())
  invoiceItemId String
  sku           String
  lager         String      @default("neuware")
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  sku       String?
  oldStock  Int?
  newStock  Int?
  note      String?
  userId    String
  createdAt DateTime     @default(now())
  item      Item?        @relation(fields: [sku], references: [sku], onUpdate: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([type])
  @@index([sku])
}
