{% stylesheet %}
  .cart-actions { display: flex; flex-direction: column; gap: var(--gap-2xs); border-bottom: 1px solid var(--color-border); padding-block: var(--padding-sm); margin-bottom: 14px; }
  .cart__summary-totals:not(:has(.cart-actions)) { margin-block-start: var(--margin-3xs); }
  .cart__installments { color: var(--color-foreground); }
  .cart__original-total-container, .cart__original-total-container * { font-size: 13px; }
  .kb-divider { height: 1px; background: var(--color-border); margin: 12px 0; }
  .kb-pline { display: flex; justify-content: space-between; align-items: center; padding: 3px 0; gap: 8px; }
  .kb-pline__label { font-size: 13px; color: var(--color-foreground); opacity: 0.6; display: flex; align-items: center; gap: 5px; }
  .kb-pline__label svg { width: 13px; height: 13px; flex-shrink: 0; }
  .kb-pline__value { font-size: 13px; font-weight: 600; color: var(--color-foreground); }
  .kb-pline__free { font-size: 13px; font-weight: 600; color: #1a8a40; }
  .kb-pline__sped { font-size: 13px; font-weight: 600; color: #854F0B; }
  .kb-total-line { display: flex; justify-content: space-between; align-items: baseline; margin-top: 2px; }
  .kb-total-line__label { font-size: 15px; font-weight: 700; color: var(--color-foreground); }
  .kb-total-line__value { font-size: 22px; font-weight: 700; color: var(--color-foreground); letter-spacing: -0.02em; }
  .kb-vat { font-size: 11px; color: var(--color-foreground); opacity: 0.45; text-align: right; margin: 2px 0 14px; }
  .kb-trust { border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: 10px 0; margin-bottom: 13px; display: flex; flex-direction: column; gap: 7px; }
  .kb-trust__item { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 500; color: var(--color-foreground); line-height: 1.3; }
  .kb-trust__item svg { flex-shrink: 0; width: 14px; height: 14px; color: #C0182A; }
  .kb-payments { margin-bottom: 14px; }
  .kb-payments__label { font-size: 10px; color: var(--color-foreground); opacity: 0.4; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 7px; }
  .kb-payments__logos { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
  .kb-payments__logos .payment-icon { height: 24px; width: auto; border-radius: 3px; border: 1px solid var(--color-border); background: var(--color-background); padding: 2px 4px; object-fit: contain; display: block; }
  .kb-checkout-btn { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 15px 20px; background: #C0182A; color: #fff !important; font-size: 15px; font-weight: 700; text-align: center; border: none; border-radius: var(--style-border-radius-buttons-primary, 4px); cursor: pointer; transition: background 0.2s, transform 0.1s; text-decoration: none; line-height: 1.3; letter-spacing: 0.03em; margin-bottom: 10px; -webkit-appearance: none; min-height: 52px; }
  .kb-checkout-btn:hover { background: #a01220; }
  .kb-checkout-btn:active { transform: scale(0.99); }
  .kb-checkout-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .kb-checkout-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
  .kb-cart-footer-links { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; margin-top: 4px; background: transparent !important; }
  .kb-cart-footer-links a { font-size: 11px; color: var(--color-foreground); opacity: 0.4; text-decoration: underline; transition: opacity 0.15s; background: transparent !important; }
  .kb-cart-footer-links a:hover { opacity: 0.7; }
  .kb-sped-hint { display: flex; gap: 10px; align-items: flex-start; background: #FFF8E1; border-left: 3px solid #F59E0B; border-radius: 0 6px 6px 0; padding: 11px 13px; margin-top: 10px; }
  .kb-sped-hint svg { width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px; color: #B45309; }
  .kb-sped-hint__text { font-size: 12.5px; line-height: 1.55; color: #78350F; }
  .kb-sped-hint__text strong { font-weight: 700; display: block; margin-bottom: 2px; font-size: 13px; }

  /* Express-Checkout ausblenden */
  .cart-drawer__summary shopify-accelerated-checkout-cart,
  .cart-drawer__summary .cart__additional-checkout-buttons,
  .cart-drawer__summary .additional-checkout-buttons,
  .cart__summary-inner shopify-accelerated-checkout-cart,
  .cart__summary-inner .cart__additional-checkout-buttons,
  .cart__summary-inner .additional-checkout-buttons,
  shopify-accelerated-checkout-cart,
  .additional-checkout-buttons { display: none !important; }

  @media screen and (max-width: 749px) {
    .kb-checkout-btn { font-size: 14px; padding: 14px 16px; min-height: 50px; }
    .kb-total-line__value { font-size: 20px; }
    .kb-trust__item { font-size: 11.5px; }
  }
{% endstylesheet %}

{%- liquid
  assign has_spedition = false
  assign has_dhl = false
  assign spedition_kosten = 0
  for item in cart.items
    assign item_tags = item.product.tags
    assign item_type = item.product.type
    assign item_spedition_kosten = 0
    if item_type == 'Einbaubackofen'
      assign has_spedition = true
      assign item_spedition_kosten = 55
    elsif item_tags contains 'set-4er'
      assign has_spedition = true
      assign item_spedition_kosten = 99
    elsif item_tags contains 'set-3er'
      assign has_spedition = true
      assign item_spedition_kosten = 85
    elsif item_tags contains 'set-2er'
      assign has_spedition = true
      assign item_spedition_kosten = 65
    else
      assign has_dhl = true
    endif
    if item_spedition_kosten > 0
      assign item_spedition_summe = item_spedition_kosten | times: item.quantity
      assign spedition_kosten = spedition_kosten | plus: item_spedition_summe
    endif
  endfor
  if settings.currency_code_enabled_cart_total
    assign total_price = cart.total_price | money_with_currency
  else
    assign total_price = cart.total_price | money
  endif
  assign spedition_kosten_cents = spedition_kosten | times: 100
  assign total_with_sped = cart.total_price | plus: spedition_kosten_cents
  assign total_with_sped_money = total_with_sped | money
-%}

<div class="cart__summary-totals">

  {%- if cart.cart_level_discount_applications.size > 0 -%}
    <div class="cart__original-total-container cart-primary-typography">
      <span class="cart__summary-item cart__original-total">
        <span class="cart__original-total-label">{{ 'content.cart_subtotal' | t }}</span>
        <span class="cart__original-total-value cart-secondary-typography">{{- cart.original_total_price | money -}}</span>
      </span>
      <div class="cart__summary-discounts">
        <ul class="discounts list-unstyled" role="list" aria-label="{{ 'content.discounts' | t }}">
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="cart__summary-item cart__discount">
              <span class="cart__discount-label">{{- 'icon-discount.svg' | inline_asset_content -}}{{ discount.title | escape }}</span>
              <span class="cart__discount-value cart-secondary-typography">-{{ discount.total_allocated_amount | money }}</span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endif -%}

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}{% render 'cart-note' %}{% endif %}
      {% if settings.show_add_discount_code %}{% render 'cart-discount' %}{% endif %}
    </div>
  {% endif %}

  <div class="kb-divider"></div>

  <div class="kb-pline">
    <span class="kb-pline__label">Zwischensumme</span>
    <span class="kb-pline__value">{{ total_price }}</span>
  </div>

  {%- if has_dhl -%}
    <div class="kb-pline">
      <span class="kb-pline__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        DHL{% if has_spedition %} (Kochfelder &amp; Hauben){% endif %}
      </span>
      <span class="kb-pline__free">Kostenlos</span>
    </div>
  {%- endif -%}

  {%- if has_spedition -%}
    <div class="kb-pline">
      <span class="kb-pline__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Spedition{% if has_dhl %} (Backofen / Set){% endif %}
      </span>
      <span class="kb-pline__sped">{{ spedition_kosten }},00 &euro;</span>
    </div>
    <div class="kb-sped-hint">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
      <div class="kb-sped-hint__text">
        <strong>Telefonnummer beim Checkout angeben</strong>
        Der Spediteur kontaktiert Sie vorab zur Terminabsprache &ndash; bitte tragen Sie Ihre Telefonnummer ein.
      </div>
    </div>
  {%- elsif has_dhl == false -%}
    <div class="kb-pline">
      <span class="kb-pline__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Versand
      </span>
      <span class="kb-pline__free">Kostenlos</span>
    </div>
  {%- endif -%}

  <div class="kb-divider"></div>

  <div class="kb-total-line">
    <span class="kb-total-line__label">Gesamt</span>
    <span class="kb-total-line__value">
      {%- if has_spedition -%}{{ total_with_sped_money }}{%- else -%}{{ total_price }}{%- endif -%}
    </span>
  </div>
  <p class="kb-vat">inkl. MwSt.</p>

  <div class="kb-trust">
    {%- if has_dhl and has_spedition == false -%}
      <div class="kb-trust__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Kostenloser DHL-Versand
      </div>
    {%- endif -%}
    <div class="kb-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      2 Jahre Garantie
    </div>
    <div class="kb-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.7A2 2 0 012 .9h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      Deutscher Kundenservice
    </div>
    <div class="kb-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      Sichere SSL-Zahlung
    </div>
  </div>

  <div class="kb-payments">
    <p class="kb-payments__label">Akzeptierte Zahlungsarten</p>
    <div class="kb-payments__logos">
      {% for type in shop.enabled_payment_types %}{{ type | payment_type_svg_tag: class: 'payment-icon' }}{% endfor %}
    </div>
  </div>

  <button type="submit" id="checkout" class="kb-checkout-btn" name="checkout" {% if cart == empty %}disabled{% endif %} form="cart-form">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    Zur Kasse
  </button>

  <div class="kb-cart-footer-links">
    <a href="{{ shop.url }}/policies/refund-policy">14 Tage Widerrufsrecht</a>
    <a href="{{ shop.url }}/policies/privacy-policy">Datenschutz</a>
    <a href="{{ shop.url }}/policies/terms-of-service">AGB</a>
  </div>

</div>
