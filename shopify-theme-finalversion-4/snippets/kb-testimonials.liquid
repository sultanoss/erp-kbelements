<style>
.kb-testi-wrap{padding:80px 0;background:#ffffff !important;color:#1C1917 !important}
.kb-testi-wrap *{box-sizing:border-box}
.kb-testi-head{text-align:center;margin-bottom:48px;padding:0 24px}
.kb-testi-head__label{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#888888 !important;margin:0 0 8px;display:block}
.kb-testi-head__title{font-size:clamp(22px,3vw,36px);font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#1C1917 !important;margin:0 0 12px}
.kb-testi-head__sub{font-size:13px;color:#666666 !important;max-width:600px;margin:0 auto;line-height:1.6}
.kb-testi-head__sub span{color:#C0182A !important;font-weight:700}
.kb-testi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;max-width:1440px;margin:0 auto}
@media(max-width:1024px){.kb-testi-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:640px){.kb-testi-grid{grid-template-columns:1fr}}
.kb-testi-card{background:#f4f4f4 !important;padding:36px 28px;display:flex;flex-direction:column}
.kb-testi-card__stars{display:flex;gap:3px;margin-bottom:16px}
.kb-testi-card__star{width:16px;height:16px;fill:#C0182A !important}
.kb-testi-card__text{font-size:14px;color:#444444 !important;line-height:1.7;margin:0;background:transparent !important;min-height:160px}
.kb-testi-card__meta{border-top:1px solid #e0e0e0;padding-top:16px;margin-top:24px}
.kb-testi-card__name{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#1C1917 !important;margin:0 0 4px;display:block}
.kb-testi-card__product{font-size:11px;color:#888888 !important;text-transform:uppercase;letter-spacing:1px;margin:0;display:block}
.kb-testi-card__badge{display:inline-flex;align-items:center;gap:5px;font-size:10px;color:#666666 !important;text-transform:uppercase;letter-spacing:1px;margin-top:8px}
.kb-testi-card__badge svg{width:12px;height:12px;fill:#4CAF50 !important}
</style>

