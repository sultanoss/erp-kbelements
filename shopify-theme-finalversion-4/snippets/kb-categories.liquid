<style>
.kb-cats{padding:48px 0;background:#fff}
.kb-cats__header{text-align:center;margin-bottom:32px;padding:0 24px}
.kb-cats__label{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#888;margin:0 0 8px}
.kb-cats__title{font-size:clamp(22px,3vw,36px);font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#111;margin:0}
.kb-cats__grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;max-width:1440px;margin:0 auto;padding:0 8px}
@media(max-width:768px){.kb-cats__grid{grid-template-columns:repeat(2,1fr)}}
.kb-cat{display:block;position:relative;aspect-ratio:3/4;overflow:hidden;text-decoration:none;transition:transform 0.3s}
.kb-cat:hover{transform:scale(1.02)}
.kb-cat__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
.kb-cat__placeholder{position:absolute;inset:0;background:#111;display:flex;align-items:center;justify-content:center}
.kb-cat__placeholder svg{opacity:0.15}
.kb-cat__gradient{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,rgba(0,0,0,0.2) 50%,transparent 100%)}
.kb-cat__label{position:absolute;bottom:0;left:0;right:0;padding:20px 16px;color:#fff;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:2px;line-height:1.3;word-break:break-word;hyphens:auto}
.kb-cat__arrow{display:block;margin-top:4px;opacity:0.6;font-size:18px}
</style>

<div class='kb-cats'>
  <div class='kb-cats__header'>
    <p class='kb-cats__label'>Entdecken Sie</p>
    <h2 class='kb-cats__title'>Unsere Produktkategorien</h2>
  </div>
  <div class='kb-cats__grid'>

    {%- assign cat_handles = 'sets-kombinationen,dunstabzugshauben,kochfelder,einbaubackofen,einbaumikrowellen' | split: ',' -%}
    {%- assign cat_display_names = 'Herdsets & Kombinationen,Abzugshauben,Kochfelder,Einbaubacköfen,Einbau-Mikrowellen' | split: ',' -%}

    {%- for handle in cat_handles -%}
      {%- assign col = collections[handle] -%}
      {%- assign display_name = cat_display_names[forloop.index0] -%}
      <a href='/collections/{{ handle }}' class='kb-cat'>
        {%- if col.image -%}
          <img class='kb-cat__img' src='{{ col.image | image_url: width: 600 }}' alt='{{ display_name | escape }}' loading='lazy' width='600'>
        {%- else -%}
          <div class='kb-cat__placeholder'>{{ 'collection' | placeholder_svg_tag }}</div>
        {%- endif -%}
        <div class='kb-cat__gradient'></div>
        <div class='kb-cat__label'>{{ display_name }}<span class='kb-cat__arrow'>&#x2192;</span></div>
      </a>
    {%- endfor -%}

  </div>
</div>
