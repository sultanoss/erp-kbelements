<style>
  .kb-pnp-banner {
    background: #1C1917;
    width: 100%;
    padding: 64px 0;
  }
  .kb-pnp-banner__inner {
    max-width: var(--page-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--page-margin, 24px);
    box-sizing: border-box;
  }
  .kb-pnp-banner__card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 16px;
    overflow: hidden;
    background: #231F1D;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
  }
  .kb-pnp-banner__img-wrap {
    overflow: hidden;
    position: relative;
  }
  .kb-pnp-banner__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .kb-pnp-banner__card:hover .kb-pnp-banner__img-wrap img {
    transform: scale(1.03);
  }
  .kb-pnp-banner__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 52px;
    color: #fff;
  }
  .kb-pnp-banner__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C0182A;
    margin-bottom: 16px;
  }
  .kb-pnp-banner__title {
    font-size: clamp(24px, 2.8vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    color: #fff;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  .kb-pnp-banner__text {
    font-size: 15px;
    line-height: 1.65;
    color: #A8A29E;
    margin: 0 0 32px;
    max-width: 420px;
  }
  .kb-pnp-banner__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #C0182A;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    align-self: flex-start;
  }
  .kb-pnp-banner__cta:hover {
    background: #a01323;
    transform: translateY(-1px);
  }
  .kb-pnp-banner__cta svg {
    transition: transform 0.2s;
  }
  .kb-pnp-banner__cta:hover svg {
    transform: translateX(4px);
  }
  @media screen and (max-width: 899px) {
    .kb-pnp-banner__card {
      grid-template-columns: 1fr;
    }
    .kb-pnp-banner__img-wrap {
      height: 260px;
    }
    .kb-pnp-banner__body {
      padding: 36px 28px 40px;
    }
    .kb-pnp-banner__title {
      font-size: 26px;
    }
  }
  @media screen and (max-width: 479px) {
    .kb-pnp-banner { padding: 40px 0; }
    .kb-pnp-banner__body { padding: 28px 20px 32px; }
  }
</style>
