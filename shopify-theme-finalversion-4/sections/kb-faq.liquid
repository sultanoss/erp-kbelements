.kb-faq__block-toggle { width: 100%; background: none; border: none; border-bottom: 2px solid currentColor; padding: 0 0 12px; margin-bottom: 0; text-align: left; font-size: 18px; font-weight: 700; color: var(--color-foreground); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 16px; font-family: inherit; text-transform: none; letter-spacing: 0; }
