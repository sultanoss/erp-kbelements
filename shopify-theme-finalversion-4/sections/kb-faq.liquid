.kb-faq__item.is-open .kb-faq__answer { max-height: 600px; padding-bottom: 16px; }
@media (max-width: 749px) { .kb-faq__question { font-size: 14px; } .kb-faq-section { padding: 32px 16px; } }
.kb-anschluss-box { max-width: 900px; margin: 0 auto 0; padding: 0 24px 8px; }
.kb-anschluss-box__title { font-size: 18px; font-weight: 700; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid currentColor; display: flex; align-items: center; gap: 10px; }
.kb-anschluss-box__title svg { flex-shrink: 0; }
.kb-anschluss-box__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
