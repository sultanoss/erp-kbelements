.kb-anschluss-box__card-title svg { color: #C0182A; flex-shrink: 0; }
.kb-anschluss-box__card-text { font-size: 13px; line-height: 1.6; opacity: 0.75; }
.kb-anschluss-box__link { font-size: 13px; color: #C0182A; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; }
.kb-anschluss-box__link:hover { text-decoration: underline; }
@media (max-width: 749px) { .kb-anschluss-box { padding: 0 16px 8px; } .kb-anschluss-box__grid { grid-template-columns: 1fr; } }
</style>

{%- liquid
  assign is_backofen = false
  assign is_induktion = false
  assign is_glaskeramik = false
  assign is_gas = false
  assign is_mikrowelle = false
  assign is_herdset = false
  if product.type == 'Einbaubackofen'
    assign is_backofen = true
  elsif product.type == 'Mikrowelle'
    assign is_mikrowelle = true
  elsif product.type == 'Herdset'
    assign is_herdset = true
  elsif product.type == 'Kochfeld'
    assign kb_betriebsart = product.metafields.kb_specs.betriebsart.value
    if kb_betriebsart == 'Glaskeramik'
      assign is_glaskeramik = true
    elsif kb_betriebsart == 'Gas'
      assign is_gas = true
    else
      assign is_induktion = true
    endif
  endif
-%}

