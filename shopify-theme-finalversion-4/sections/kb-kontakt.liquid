<style>
/* ===== LAYOUT ===== */
.kb-kontakt-page{padding:0;font-family:inherit;overflow-x:hidden;}
.kb-kontakt-inner{max-width:1200px;margin:0 auto;padding:0 24px;}
@media(max-width:749px){.kb-kontakt-inner{padding:0 16px;}}
.kb-kontakt-sep{width:100vw;margin-left:50%;transform:translateX(-50%);background:#F5F3EF;height:8px;}
.kb-kontakt-section-title{font-size:22px;font-weight:700;color:#1C1917;margin:0 0 24px;padding-bottom:12px;border-bottom:2px solid #C0182A;display:inline-block;}
@media(max-width:749px){.kb-kontakt-section-title{font-size:18px;}}

/* ===== PAGE HEADER ===== */
.kb-kontakt-header{padding:56px 0 48px;border-bottom:1px solid #EAE8E4;}
@media(max-width:749px){.kb-kontakt-header{padding:36px 0 28px;}}
.kb-kontakt-header__badge{
  display:inline-block;
  background:#C0182A;
  color:#fff;
  font-size:11px;
  font-weight:700;
  letter-spacing:.1em;
  text-transform:uppercase;
  padding:4px 10px;
  border-radius:4px;
  margin-bottom:16px;
}
.kb-kontakt-header__title{
  font-size:clamp(28px,4vw,44px);
  font-weight:800;
  color:#1C1917;
  line-height:1.15;
  margin:0 0 14px;
}
.kb-kontakt-header__sub{font-size:17px;color:#555;line-height:1.65;margin:0;max-width:600px;}
@media(max-width:749px){.kb-kontakt-header__sub{font-size:15px;}}

/* ===== KONTAKT KARTEN ===== */
.kb-kontakt-cards-wrap{padding:56px 0;}
@media(max-width:749px){.kb-kontakt-cards-wrap{padding:32px 0;}
}
.kb-kontakt-cards{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
@media(max-width:700px){.kb-kontakt-cards{grid-template-columns:1fr;gap:16px;}}
.kb-kontakt-card{
  background:#F5F3EF;
  border-radius:10px;
  padding:28px 24px;
  display:flex;
  flex-direction:column;
  gap:10px;
}
@media(max-width:749px){.kb-kontakt-card{padding:20px 16px;}}
.kb-kontakt-card--primary{background:#1C1917;}
.kb-kontakt-card__icon{font-size:28px;line-height:1;color:#C0182A;}
.kb-kontakt-card__title{font-size:16px;font-weight:700;color:#1C1917;margin:0;}
.kb-kontakt-card--primary .kb-kontakt-card__title{color:#fff;}
.kb-kontakt-card__text{font-size:14px;color:#555;line-height:1.65;margin:0;flex:1;}
.kb-kontakt-card--primary .kb-kontakt-card__text{color:#aaa;}
.kb-kontakt-card__cta{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:#C0182A;
  color:#fff !important;
  padding:11px 22px;
  border-radius:6px;
  text-decoration:none;
  font-size:14px;
  font-weight:600;
  margin-top:6px;
  align-self:flex-start;
  transition:background .2s;
}
.kb-kontakt-card__cta:hover{background:#a01020;}
@media(max-width:500px){.kb-kontakt-card__cta{width:100%;justify-content:center;}}

/* ===== THEMEN ===== */
.kb-kontakt-topics-wrap{padding:56px 0;}
@media(max-width:749px){.kb-kontakt-topics-wrap{padding:36px 0;}}
.kb-kontakt-topics{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:600px){.kb-kontakt-topics{grid-template-columns:1fr;}}
.kb-kontakt-topic{
  display:flex;
  align-items:flex-start;
  gap:14px;
  padding:18px 20px;
  background:#fff;
  border:1px solid #eee;
  border-radius:10px;
  text-decoration:none;
  transition:border-color .2s,box-shadow .2s;
  box-shadow:0 1px 4px rgba(0,0,0,.04);
}
@media(max-width:749px){.kb-kontakt-topic{padding:14px 16px;}}
.kb-kontakt-topic:hover{border-color:#C0182A;box-shadow:0 2px 12px rgba(192,24,42,.08);}
.kb-kontakt-topic__icon{font-size:22px;flex-shrink:0;line-height:1;margin-top:2px;color:#C0182A;}
.kb-kontakt-topic__title{font-size:14px;font-weight:700;color:#1C1917;margin:0 0 4px;}
.kb-kontakt-topic__text{font-size:13px;color:#666;line-height:1.5;margin:0;}
.kb-kontakt-topic:hover .kb-kontakt-topic__title{color:#C0182A;}

/* ===== TIPPS ===== */
.kb-kontakt-tips-wrap{padding:56px 0;}
@media(max-width:749px){.kb-kontakt-tips-wrap{padding:36px 0;}}
.kb-kontakt-tips{
  background:#1C1917;
  border-radius:12px;
  padding:40px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px 40px;
}
@media(max-width:700px){.kb-kontakt-tips{grid-template-columns:1fr;padding:24px 20px;gap:12px;}}
.kb-kontakt-tip{display:flex;align-items:flex-start;gap:12px;}
.kb-kontakt-tip__num{
  width:28px;height:28px;flex-shrink:0;
  background:#C0182A;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:13px;font-weight:800;margin-top:1px;
}
.kb-kontakt-tip__text{font-size:14px;color:#bbb;line-height:1.6;margin:0;}
.kb-kontakt-tip__text strong{color:#fff;font-weight:700;}

/* ===== WEITERE SEITEN ===== */
.kb-kontakt-links-wrap{padding:48px 0 56px;}
@media(max-width:749px){.kb-kontakt-links-wrap{padding:32px 0 40px;}}
.kb-kontakt-links{display:flex;flex-wrap:wrap;gap:10px;}
.kb-kontakt-links a{
  display:inline-flex;align-items:center;gap:6px;
  color:#333 !important;padding:9px 16px;border-radius:6px;
  text-decoration:none;font-weight:500;font-size:13.5px;
  border:1px solid #ddd;background:#F5F3EF;transition:all .2s;white-space:nowrap;
}
.kb-kontakt-links a:hover{border-color:#C0182A;color:#C0182A !important;background:#fff;}
</style>

