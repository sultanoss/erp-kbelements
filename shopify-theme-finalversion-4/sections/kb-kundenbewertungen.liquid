<style>
.kb-reviews-header-img{
  width:100vw;
  margin-left:50%;
  transform:translateX(-50%);
  margin-top:-40px;
}
.kb-reviews-header-img img{width:100%;height:auto;display:block;}
@media(max-width:749px){
  .kb-reviews-header-img{margin-top:0;}
}
.kb-reviews-page{padding:0;font-family:inherit;}
.kb-reviews-inner{max-width:1200px;margin:0 auto;padding:0 24px;}
@media(max-width:749px){.kb-reviews-inner{padding:0 16px;}}
.kb-reviews-sep{width:100vw;margin-left:50%;transform:translateX(-50%);background:#F5F3EF;height:8px;}
.kb-reviews-trust-wrap{padding:56px 0;}
@media(max-width:749px){.kb-reviews-trust-wrap{padding:36px 0;}}
.kb-reviews-trust{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
@media(max-width:600px){.kb-reviews-trust{grid-template-columns:1fr;gap:12px;}}
.kb-reviews-trust__item{text-align:center;padding:28px 16px;border:1px solid #eee;border-radius:8px;}
@media(max-width:600px){.kb-reviews-trust__item{padding:20px 16px;display:flex;align-items:center;gap:16px;text-align:left;}}
.kb-reviews-trust__icon{font-size:32px;margin-bottom:10px;color:#C0182A;}
@media(max-width:600px){.kb-reviews-trust__icon{margin-bottom:0;flex-shrink:0;}}
.kb-reviews-trust__number{font-size:32px;font-weight:800;color:#1C1917;margin-bottom:4px;}
@media(max-width:600px){.kb-reviews-trust__number{font-size:24px;}}
.kb-reviews-trust__label{font-size:14px;color:#666;}
.kb-reviews-section-title{font-size:22px;font-weight:700;color:#1C1917;margin-bottom:24px;padding-bottom:12px;border-bottom:2px solid #C0182A;display:inline-block;}
@media(max-width:749px){.kb-reviews-section-title{font-size:18px;}}
.kb-reviews-cards-wrap{padding:56px 0;}
@media(max-width:749px){.kb-reviews-cards-wrap{padding:36px 0;}}
.kb-reviews-live{width:100%;min-height:240px;}
.kb-reviews-live .jdgm-all-reviews-widget{width:100%;}
.kb-reviews-cta-wrap{padding:56px 0;text-align:center;}
@media(max-width:749px){.kb-reviews-cta-wrap{padding:36px 0;}}
.kb-reviews-cta-title{font-size:24px;font-weight:800;color:#1C1917;margin-bottom:10px;}
@media(max-width:749px){.kb-reviews-cta-title{font-size:20px;}}
.kb-reviews-cta-sub{font-size:17px;color:#444;font-weight:500;margin-bottom:28px;}
@media(max-width:749px){.kb-reviews-cta-sub{font-size:15px;}}
.kb-reviews-cta-sub strong{color:#C0182A;font-weight:700;}
.kb-reviews-categories{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;}
.kb-reviews-categories a{display:inline-flex;align-items:center;gap:8px;color:#333 !important;padding:10px 18px;border-radius:6px;text-decoration:none;font-weight:500;font-size:13.5px;letter-spacing:.01em;border:1px solid #ddd;background:#F5F3EF;transition:all .2s;white-space:nowrap;}
.kb-reviews-categories a:hover{border-color:#C0182A;color:#C0182A !important;background:#fff;}
.kb-cat-arrow{font-size:14px;color:#999;transition:color .2s,transform .2s;line-height:1;}
.kb-reviews-categories a:hover .kb-cat-arrow{color:#C0182A;transform:translateX(2px);}
</style>

<div class="kb-reviews-header-img">
  <img src="https://cdn.shopify.com/s/files/1/0963/1852/1608/files/bewertungen.png?v=1782495626" alt="Zufriedene KB ELEMENTS Kunden – über 2.463 verifizierte Bewertungen" loading="eager" width="1200" height="400">
</div>

<div class="kb-reviews-page">

  <div class="kb-reviews-sep"></div>

  <div class="kb-reviews-trust-wrap">
    <div class="kb-reviews-inner">
      <h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0;">Kundenbewertungen KB ELEMENTS – über 2.463 verifizierte Bewertungen</h1>
      <div class="kb-reviews-trust">
        <div class="kb-reviews-trust__item">
          <div class="kb-reviews-trust__icon">&#9733;</div>
          <div><div class="kb-reviews-trust__number">4.9/5</div><div class="kb-reviews-trust__label">Durchschnittsbewertung</div></div>
        </div>
        <div class="kb-reviews-trust__item">
          <div class="kb-reviews-trust__icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C0182A" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <div><div class="kb-reviews-trust__number">2.463</div><div class="kb-reviews-trust__label">Verifizierte Bewertungen</div></div>
        </div>
        <div class="kb-reviews-trust__item">
          <div class="kb-reviews-trust__icon">&#10003;</div>
          <div><div class="kb-reviews-trust__number">98%</div><div class="kb-reviews-trust__label">Empfehlen KB ELEMENTS</div></div>
        </div>
      </div>
    </div>
  </div>

  <div class="kb-reviews-sep"></div>

  <div class="kb-reviews-cards-wrap">
    <div class="kb-reviews-inner">
      <h2 class="kb-reviews-section-title">Bewertungen unserer Kunden</h2>
      <div class="kb-reviews-live">
        <div class="jdgm-all-reviews-widget" data-per-page="10"></div>
      </div>
    </div>
  </div>

  

  <div class="kb-reviews-cta-wrap">
    <div class="kb-reviews-inner">
      <p class="kb-reviews-cta-title">Finden Sie das passende Gerät für Ihre Küche</p>
      <p class="kb-reviews-cta-sub">Von <strong>über 2.463 Kunden</strong> vertraut &ndash; jetzt entdecken</p>
      <div class="kb-reviews-categories">
        <a href="{{ routes.collections_url }}/sets-kombinationen">Herdsets &amp; Kombinationen <span class="kb-cat-arrow">&#8594;</span></a>
        <a href="{{ routes.collections_url }}/kochfelder">Kochfelder <span class="kb-cat-arrow">&#8594;</span></a>
        <a href="{{ routes.collections_url }}/einbaubackofen">Einbaubacköfen <span class="kb-cat-arrow">&#8594;</span></a>
        <a href="{{ routes.collections_url }}/dunstabzugshauben">Abzugshauben <span class="kb-cat-arrow">&#8594;</span></a>
        <a href="{{ routes.collections_url }}/einbaumikrowellen">Einbaumikrowellen <span class="kb-cat-arrow">&#8594;</span></a>
      </div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "KB Kundenbewertungen",
  "settings": []
}
{% endschema %}
