{% comment %}
  kb-antiscratch-header.liquid
  AntiScratch Collection Header
  Video links (kein Crop, kein Padding) · Text rechts schmal · Mobile gestapelt
{% endcomment %}

<section class="kb-antiscratch-header">
  <div class="kb-ash__inner">

    {%- comment -%} VIDEO {%- endcomment -%}
    <div class="kb-ash__media">
      <div class="kb-ash__video-wrap">
        <video
          id="kb-ash-video"
          class="kb-ash__video"
          src="https://cdn.shopify.com/videos/c/o/v/5fd95bb30bfd4e3298335a1f1e1a109a.mp4"
          autoplay muted loop playsinline preload="auto"
        ></video>
        <div class="kb-ash__controls">
          <div class="kb-ash__progress-wrap">
            <div class="kb-ash__progress-bar" id="kb-ash-progress-bar">
              <div class="kb-ash__progress-fill" id="kb-ash-progress-fill"></div>
              <div class="kb-ash__progress-thumb" id="kb-ash-progress-thumb"></div>
            </div>
            <div class="kb-ash__time" id="kb-ash-time">0:00 / 0:00</div>
          </div>
          <div class="kb-ash__btn-row">
            <button class="kb-ash__btn" id="kb-ash-back" aria-label="-10s">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M12.5 4C8.5 4 5.5 7 5.5 11H3l3.5 3.5L10 11H7.5c0-2.8 2.2-5 5-5s5 2.2 5 5-2.2 5-5 5c-1.4 0-2.6-.6-3.5-1.5L7.6 16c1.2 1.2 2.8 1.9 4.6 2 3.9.1 7.1-2.9 7.3-6.8.2-4.1-3-7.2-7-7.2z"/><text x="9.5" y="13.5" font-size="5.5" font-weight="bold" font-family="sans-serif" fill="white" text-anchor="middle">10</text></svg>
            </button>
            <button class="kb-ash__btn kb-ash__btn--play" id="kb-ash-play" aria-label="Play/Pause">
              <svg class="kb-ash__ic-pause" width="18" height="18" viewBox="0 0 24 24" fill="white"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
              <svg class="kb-ash__ic-play" width="18" height="18" viewBox="0 0 24 24" fill="white" style="display:none"><path d="M8 5v14l11-7z"/></svg>
            </button>
            <button class="kb-ash__btn" id="kb-ash-fwd" aria-label="+10s">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M11.5 4c4 0 7 3 7 7h2.5L17.5 14.5 14 11h2.5c0-2.8-2.2-5-5-5s-5 2.2-5 5 2.2 5 5 5c1.4 0 2.6-.6 3.5-1.5l1.4 1.4C15.2 18 13.4 18.8 11.5 19c-3.9 0-7-3.1-7-7s3.1-7 7-7z"/><text x="11.5" y="13.5" font-size="5.5" font-weight="bold" font-family="sans-serif" fill="white" text-anchor="middle">10</text></svg>
            </button>
            <button class="kb-ash__btn" id="kb-ash-mute" aria-label="Ton">
              <svg class="kb-ash__ic-muted" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5z" stroke="white" stroke-width="2" stroke-linejoin="round"/><line x1="23" y1="9" x2="17" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/><line x1="17" y1="9" x2="23" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
              <svg class="kb-ash__ic-unmuted" width="18" height="18" viewBox="0 0 24 24" fill="none" style="display:none"><path d="M11 5L6 9H2v6h4l5 4V5z" stroke="white" stroke-width="2" stroke-linejoin="round"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="white" stroke-width="2" stroke-linecap="round"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} TEXT {%- endcomment -%}
    <div class="kb-ash__content">
      <p class="kb-ash__label"><span aria-hidden="true">✨</span> {{ section.settings.label | default: 'Premium Oberfläche' }}</p>
      <h1 class="kb-ash__title">{{ section.settings.heading | default: 'AntiScratch' }}</h1>
      {%- if section.settings.description != blank -%}
        <p class="kb-ash__desc">{{ section.settings.description }}</p>
      {%- endif -%}
      <ul class="kb-ash__usps" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'usp' -%}
            <li class="kb-ash__usp" {{ block.shopify_attributes }}>
              <span class="kb-ash__usp-icon" aria-hidden="true">
                {%- if block.settings.icon == 'check' -%}<svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- elsif block.settings.icon == 'shield' -%}<svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1L12 3.5V7C12 10 7 13 7 13S2 10 2 7V3.5L7 1Z" stroke="white" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- elsif block.settings.icon == 'star' -%}<svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1L8.8 5.2L13.4 5.6L10 8.6L11 13.2L7 10.8L3 13.2L4 8.6L0.6 5.6L5.2 5.2Z" stroke="white" stroke-width="1.2" stroke-linejoin="round"/></svg>
                {%- else -%}<svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- endif -%}
              </span>
              <div class="kb-ash__usp-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}<span>{{ block.settings.subtitle }}</span>{%- endif -%}
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

  </div>
</section>

<style>
  .kb-antiscratch-header {
    background-color: #1C1917;
    width: 100%;
    overflow: hidden;
  }

  /* Grid: Video nimmt so viel Platz wie es braucht */
  .kb-ash__inner {
    display: flex;
    flex-direction: row;
    max-width: 1440px;
    margin: 0 auto;
    align-items: stretch;
  }

  /* Video-Seite: kein Padding, kein Hintergrund-Überstand */
  .kb-ash__media {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: stretch;
  }

  .kb-ash__video-wrap {
    position: relative;
    width: 100%;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Video: echte Größe, kein Crop, kein Balken */
  .kb-ash__video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    background: #000;
  }

  /* Steuerleiste */
  .kb-ash__controls {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, transparent 100%);
    padding: 32px 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .kb-ash__video-wrap:hover .kb-ash__controls,
  .kb-ash__video-wrap.kb-ash--paused .kb-ash__controls { opacity: 1; }

  .kb-ash__progress-wrap { display: flex; align-items: center; gap: 10px; }
  .kb-ash__progress-bar {
    flex: 1; height: 4px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px; position: relative; cursor: pointer;
  }
  .kb-ash__progress-bar:hover { height: 6px; }
  .kb-ash__progress-fill {
    position: absolute; top: 0; left: 0; bottom: 0;
    width: 0%; background: #C0182A; border-radius: 2px; pointer-events: none;
  }
  .kb-ash__progress-thumb {
    position: absolute; top: 50%; left: 0%;
    transform: translate(-50%, -50%);
    width: 12px; height: 12px;
    background: #fff; border-radius: 50%;
    pointer-events: none; opacity: 0; transition: opacity 0.15s;
  }
  .kb-ash__progress-bar:hover .kb-ash__progress-thumb { opacity: 1; }
  .kb-ash__time {
    font-size: 11px; color: rgba(255,255,255,0.85);
    white-space: nowrap; min-width: 76px; text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .kb-ash__btn-row { display: flex; align-items: center; gap: 4px; }
  .kb-ash__btn {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: transparent; border: none; cursor: pointer; transition: background 0.15s;
  }
  .kb-ash__btn:hover { background: rgba(192,24,42,0.65); }
  .kb-ash__btn--play {
    width: 42px; height: 42px;
    background: rgba(255,255,255,0.18); margin: 0 4px;
  }
  .kb-ash__btn--play:hover { background: #C0182A; }

  /* Text-Seite: schmal, vertikal zentriert */
  .kb-ash__content {
    flex: 0 0 300px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 36px 32px 36px 28px;
    color: #fff;
  }
  .kb-ash__label {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #C0182A; margin: 0 0 12px;
  }
  .kb-ash__title {
    font-size: clamp(24px, 2.5vw, 40px);
    font-weight: 700; line-height: 1.08;
    color: #fff; margin: 0 0 12px; letter-spacing: -0.02em;
  }
  .kb-ash__desc {
    font-size: 13px; line-height: 1.6;
    color: #D6D3D1; margin: 0 0 20px;
  }
  .kb-ash__usps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .kb-ash__usp { display: flex; align-items: flex-start; gap: 10px; }
  .kb-ash__usp-icon {
    display: flex; align-items: center; justify-content: center;
    width: 24px; height: 24px; min-width: 24px;
    background: #C0182A; border-radius: 50%; margin-top: 1px;
  }
  .kb-ash__usp-text { display: flex; flex-direction: column; gap: 1px; }
  .kb-ash__usp-text strong { font-size: 13px; font-weight: 600; color: #fff; line-height: 1.3; }
  .kb-ash__usp-text span { font-size: 11px; color: #A8A29E; line-height: 1.4; }

  /* Mobile */
  @media screen and (max-width: 767px) {
    .kb-ash__inner { flex-direction: column; }
    .kb-ash__media { order: 1; }
    .kb-ash__content { order: 2; flex: unset; padding: 28px 20px 32px; }
    .kb-ash__title { font-size: 26px; }
    .kb-ash__controls { opacity: 1; }
  }
</style>

<script>
(function() {
  var video = document.getElementById('kb-ash-video');
  var wrap = video && video.closest('.kb-ash__video-wrap');
  var btnPlay = document.getElementById('kb-ash-play');
  var btnBack = document.getElementById('kb-ash-back');
  var btnFwd = document.getElementById('kb-ash-fwd');
  var btnMute = document.getElementById('kb-ash-mute');
  var progressBar = document.getElementById('kb-ash-progress-bar');
  var progressFill = document.getElementById('kb-ash-progress-fill');
  var progressThumb = document.getElementById('kb-ash-progress-thumb');
  var timeEl = document.getElementById('kb-ash-time');
  if (!video) return;
  var icPause = btnPlay && btnPlay.querySelector('.kb-ash__ic-pause');
  var icPlay = btnPlay && btnPlay.querySelector('.kb-ash__ic-play');
  var icMuted = btnMute && btnMute.querySelector('.kb-ash__ic-muted');
  var icUnmuted = btnMute && btnMute.querySelector('.kb-ash__ic-unmuted');
  function fmt(s){s=Math.floor(s||0);return Math.floor(s/60)+':'+(s%60<10?'0':'')+(s%60);}
  function updateProgress(){
    if(!video.duration)return;
    var p=(video.currentTime/video.duration)*100;
    if(progressFill)progressFill.style.width=p+'%';
    if(progressThumb)progressThumb.style.left=p+'%';
    if(timeEl)timeEl.textContent=fmt(video.currentTime)+' / '+fmt(video.duration);
  }
  video.addEventListener('timeupdate',updateProgress);
  video.addEventListener('loadedmetadata',updateProgress);
  var dragging=false;
  function seek(e){
    if(!video.duration)return;
    var rect=progressBar.getBoundingClientRect();
    var x=(e.touches?e.touches[0].clientX:e.clientX)-rect.left;
    video.currentTime=Math.max(0,Math.min(1,x/rect.width))*video.duration;
  }
  if(progressBar){
    progressBar.addEventListener('mousedown',function(e){dragging=true;seek(e);});
    progressBar.addEventListener('touchstart',function(e){dragging=true;seek(e);},{passive:true});
    document.addEventListener('mousemove',function(e){if(dragging)seek(e);});
    document.addEventListener('touchmove',function(e){if(dragging)seek(e);},{passive:true});
    document.addEventListener('mouseup',function(){dragging=false;});
    document.addEventListener('touchend',function(){dragging=false;});
  }
  function syncPlay(){
    if(icPause)icPause.style.display=video.paused?'none':'';
    if(icPlay)icPlay.style.display=video.paused?'':'none';
    if(wrap)wrap.classList.toggle('kb-ash--paused',video.paused);
  }
  if(btnPlay)btnPlay.addEventListener('click',function(){
    if(video.paused){video.loop=true;video.play();}else{video.pause();video.loop=false;}
  });
  video.addEventListener('play',syncPlay);
  video.addEventListener('pause',syncPlay);
  if(btnBack)btnBack.addEventListener('click',function(){video.currentTime=Math.max(0,video.currentTime-10);});
  if(btnFwd)btnFwd.addEventListener('click',function(){video.currentTime=Math.min(video.duration||0,video.currentTime+10);});
  if(btnMute)btnMute.addEventListener('click',function(){
    video.muted=!video.muted;
    if(icMuted)icMuted.style.display=video.muted?'':'none';
    if(icUnmuted)icUnmuted.style.display=video.muted?'none':'';
  });
})();
</script>

{% schema %}
{
  "name": "AntiScratch Header",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label-Text", "default": "Premium Oberfläche" },
    { "type": "text", "id": "heading", "label": "Überschrift (H1)", "default": "AntiScratch" },
    { "type": "textarea", "id": "description", "label": "Beschreibungstext", "default": "Unsere AntiScratch-Kochfelder bieten eine besonders widerstandsfähige Glaskeramik-Oberfläche – langlebig, pflegeleicht und ästhetisch überzeugend." }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{"value":"check","label":"Haken"},{"value":"shield","label":"Schild"},{"value":"star","label":"Stern"}], "default": "check" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Kratzfest" },
        { "type": "text", "id": "subtitle", "label": "Untertitel (optional)", "default": "Hochwertige Verarbeitung für täglichen Einsatz" }
      ]
    }
  ],
  "presets": [{
    "name": "AntiScratch Header",
    "blocks": [
      {"type":"usp","settings":{"icon":"check","title":"Kratzfest","subtitle":"Widerstandsfähige Oberfläche für den täglichen Einsatz"}},
      {"type":"usp","settings":{"icon":"shield","title":"Fleckenresistent","subtitle":"Leicht zu reinigen – auch bei hartnäckigen Verschmutzungen"}},
      {"type":"usp","settings":{"icon":"star","title":"Langlebig","subtitle":"Hochwertige Verarbeitung für jahrelange Freude"}}
    ]
  }]
}
{% endschema %}
