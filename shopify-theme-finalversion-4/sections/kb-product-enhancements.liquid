{%- liquid
  assign rating_value = product.metafields.reviews.rating.value
  assign rating_count = product.metafields.reviews.rating_count.value | plus: 0
-%}
{%- if rating_value != blank and rating_count > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ shop.url | append: product.url | json }},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ rating_value }}",
    "reviewCount": "{{ rating_count }}",
    "bestRating": "5",
    "worstRating": "1"
  }
}
</script>
{%- endif -%}

{{ 'kb-product.css' | asset_url | stylesheet_tag }}

<style>
  .jdgm-prev-badge { display: block !important; visibility: visible !important; }
  .variant-option--buttons,
  .variant-option--equal-width-buttons { display: none !important; }
  .product-media-container, .product__media-item, .product__media { max-height: 520px !important; }
  .product-media-container img, .product__media img { max-height: 520px !important; object-fit: contain !important; }
  .kb-breadcrumb { display:flex; align-items:center; flex-wrap:wrap; gap:4px; font-size:12px; color:#888; margin:0 0 12px; padding:0; list-style:none; }
  .kb-breadcrumb a { color:#888; text-decoration:none; }
  .kb-breadcrumb a:hover { color:#C0182A; text-decoration:underline; }
  .kb-breadcrumb__sep { color:#bbb; font-size:11px; }
  .kb-price-wrap { display:flex; align-items:center; gap:10px; margin:6px 0 10px; flex-wrap:wrap; }
  .kb-shipping-note { display:flex; align-items:center; gap:7px; font-size:13px; color:#555; font-weight:700; margin:0 0 10px; }
  .kb-price-vat { font-size:11px; color:#888; font-weight:400; }
  .kb-price-sale { font-size:1.6rem; font-weight:700; color:#C0182A; }
  .kb-price-regular { font-size:1.6rem; font-weight:700; color:#111; }
  .kb-price-original { font-size:1.1rem; color:#999; text-decoration:line-through; }
  .kb-price-badge { background:#C0182A; color:#fff; font-size:11px; font-weight:700; padding:2px 7px; border-radius:4px; }
  .kb-info-row { display:flex; align-items:center; gap:18px; flex-wrap:wrap; margin:10px 0; }
  .kb-urgency { display:flex; align-items:center; gap:7px; font-size:13px; color:#2a7a2a; font-weight:500; margin:0; }
  .kb-energie-badge-wrap { display:inline-flex; align-items:center; gap:10px; margin:0; cursor:pointer; }
  .kb-energie-badge-arrow { display:flex; align-items:center; justify-content:center; color:#fff; font-size:20px; font-weight:800; min-width:46px; width:auto; height:36px; padding:0 16px 0 9px; box-sizing:border-box; clip-path:polygon(0 0,82% 0,100% 50%,82% 100%,0 100%); letter-spacing:-1px; text-shadow:0 1px 2px rgba(0,0,0,0.4); white-space:nowrap; }
  .kb-energie-badge-text { font-size:12px; color:#444; line-height:1.3; }
  .kb-energie-badge-text strong { display:block; font-size:13px; color:#111; }
  .kb-energie-badge-wrap:hover .kb-energie-badge-arrow { outline:2px solid #333; }
  .kb-energie-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; justify-content:center; align-items:flex-start; padding:40px 16px; box-sizing:border-box; overflow-y:auto; }
  .kb-energie-modal-overlay.open { display:flex; }
  .kb-energie-modal { background:#fff; border-radius:10px; padding:48px 24px 24px; max-width:480px; width:100%; position:relative; text-align:center; max-height:calc(100vh - 80px); overflow-y:auto; flex-shrink:0; margin:auto; }
  .kb-energie-modal img { max-width:100%; height:auto; display:block; margin:0 auto; }
  .kb-energie-modal-close { position:absolute; top:10px; right:14px; background:none; border:none; font-size:28px; cursor:pointer; color:#333; line-height:1; z-index:1; }
  .kb-usp-wrap { display:grid; grid-template-columns:1fr 1fr; gap:6px 12px; margin:10px 0; padding:12px 14px; background:#fafafa; border:1px solid #eee; border-radius:8px; }
  .kb-usp-item { display:flex; align-items:flex-start; gap:7px; font-size:14px; color:#333; line-height:1.4; }
  .kb-usp-item .kb-check { color:#C0182A; font-size:14px; font-weight:700; flex-shrink:0; margin-top:1px; }
  .kb-pay-logos { display:flex; flex-direction:column; align-items:center; gap:8px; margin:12px 0 0; padding:12px 0 0; border-top:1px solid #eee; }
  .kb-pay-logos__label { font-size:11px; color:#999; text-transform:uppercase; letter-spacing:0.06em; }
  .kb-pay-logos__row { display:flex; align-items:center; justify-content:center; gap:6px; flex-wrap:wrap; }
