<script>
(function(){
  function wrap(){
    document.querySelectorAll('product-card').forEach(function(c){
      if(c.querySelector('.kb-col-actions')) return;
      if(!c.querySelector('.kb-col-atc')) return;
      var els=['.kb-col-energy','.kb-col-available','.kb-col-atc','.kb-col-qv'].map(function(s){return c.querySelector(s);}).filter(Boolean);
      if(!els.length) return;
      var d=document.createElement('div'); d.className='kb-col-actions'; c.appendChild(d);
      els.forEach(function(e){ d.appendChild(e); });
    });
  }
  if(document.readyState!=='loading') wrap(); else document.addEventListener('DOMContentLoaded', wrap);
  window.addEventListener('load', wrap);
  setTimeout(wrap,600); setTimeout(wrap,1500);
})();
</script>

