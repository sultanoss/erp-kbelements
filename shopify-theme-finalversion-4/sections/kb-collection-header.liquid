{%- if show_header -%}
{%- comment -%}
  KB Performance-Fix (2026-06-30): fetchpriority="high" da LCP-Element
  (siehe oberer Kommentar-Block in der Versionshistorie). Zusätzlich jetzt
  width/height=1200x700 gesetzt (Original-Quellbild-Maße aller Header-PNGs),
  damit der Browser sofort den Platz reserviert und kein Layout-Shift (CLS)
  während des Ladens entsteht. object-fit:cover in der CSS sorgt weiterhin
  dafür, dass das Bild visuell exakt wie vorher den Container ausfüllt —
  width/height hier sind nur Seitenverhältnis-Hinweise für den Browser,
  kein fixes Rendering-Maß.
{%- endcomment -%}
<div class="kb-col-header-wrap">
  <div class="kb-col-header-img">
    <img src="{{ header_image }}" alt="{{ collection.title }}" loading="eager" fetchpriority="high" width="1200" height="700">
  </div>
  <div class="kb-col-header-content">
    <h1 class="kb-col-header__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="kb-col-header__desc">{{ collection.description | strip_html }}</p>
    {%- endif -%}
    <div class="kb-col-header__usp">
      <div class="kb-col-header__usp-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>2 Jahre Garantie</div>
      <div class="kb-col-header__usp-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>{{ usp_versand }}</div>
      <div class="kb-col-header__usp-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>Eigene Werkstatt</div>
      <div class="kb-col-header__usp-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>14 Tage Rückgabe</div>
      <div class="kb-col-header__usp-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Sichere Zahlung</div>
      <div class="kb-col-header__usp-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><polyline points="9 12 11 14 15 10"/></svg>Deutscher Hersteller</div>
    </div>
  </div>
</div>
{%- endif -%}

{%- if show_antiscratch -%}
<style>
@keyframes kb-spin{to{transform:rotate(360deg);}}
@keyframes kb-progress{0%{transform:translateX(-100%);}60%{transform:translateX(260%);}100%{transform:translateX(260%);}}
.kb-ash__spinner{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:16px;z-index:10;
  background:#000;
  transition:opacity 0.5s ease;
}
.kb-ash__spinner.is-hidden{opacity:0;pointer-events:none;}
.kb-ash__spinner-ring{
  width:48px;height:48px;border-radius:50%;
  border:3px solid rgba(255,255,255,0.1);
  border-top-color:#C0182A;
  animation:kb-spin 0.8s linear infinite;
}
.kb-ash__spinner-label{
  font-size:11px;color:rgba(255,255,255,0.4);
  letter-spacing:0.1em;text-transform:uppercase;
  font-family:sans-serif;
}
.kb-ash__spinner-bar{
  position:absolute;bottom:0;left:0;right:0;height:2px;
  background:rgba(255,255,255,0.06);overflow:hidden;
}
.kb-ash__spinner-bar::after{
  content:'';display:block;height:100%;width:35%;
  background:#C0182A;border-radius:2px;
  animation:kb-progress 1.4s ease-in-out infinite;
}
</style>
<div class="kb-ash__inner">
  <div class="kb-ash__media">
    <div class="kb-ash__spinner" id="kb-ash-spinner">
      <div class="kb-ash__spinner-ring"></div>
      <span class="kb-ash__spinner-label">Video wird geladen</span>
      <div class="kb-ash__spinner-bar"></div>
    </div>
    <video id="kb-ash-video" class="kb-ash__video" src="https://cdn.shopify.com/videos/c/o/v/5fd95bb30bfd4e3298335a1f1e1a109a.mp4" autoplay muted loop playsinline preload="auto"></video>
    <div class="kb-ash__controls">
      <div style="display:flex;align-items:center;gap:10px;">
        <div id="kb-ash-progress-bar" style="flex:1;height:4px;background:rgba(255,255,255,.3);border-radius:2px;position:relative;cursor:pointer;">
          <div id="kb-ash-progress-fill" style="position:absolute;top:0;left:0;bottom:0;width:0%;background:#C0182A;border-radius:2px;"></div>
          <div id="kb-ash-progress-thumb" style="position:absolute;top:50%;left:0%;transform:translate(-50%,-50%);width:12px;height:12px;background:#fff;border-radius:50%;opacity:0;"></div>
        </div>
        <div id="kb-ash-time" style="font-size:11px;color:rgba(255,255,255,.85);white-space:nowrap;min-width:76px;text-align:right;">0:00 / 0:00</div>
      </div>
      <div style="display:flex;align-items:center;gap:4px;">
        <button id="kb-ash-back" aria-label="-10s" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:transparent;border:none;cursor:pointer;"><svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M12.5 4C8.5 4 5.5 7 5.5 11H3l3.5 3.5L10 11H7.5c0-2.8 2.2-5 5-5s5 2.2 5 5-2.2 5-5 5c-1.4 0-2.6-.6-3.5-1.5L7.6 16c1.2 1.2 2.8 1.9 4.6 2 3.9.1 7.1-2.9 7.3-6.8.2-4.1-3-7.2-7-7.2z"/><text x="9.5" y="13.5" font-size="5.5" font-weight="bold" font-family="sans-serif" fill="white" text-anchor="middle">10</text></svg></button>
        <button id="kb-ash-play" aria-label="Play/Pause" style="display:flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.18);border:none;cursor:pointer;margin:0 4px;"><svg id="kb-ash-ic-pause" width="18" height="18" viewBox="0 0 24 24" fill="white"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg><svg id="kb-ash-ic-play" width="18" height="18" viewBox="0 0 24 24" fill="white" style="display:none"><path d="M8 5v14l11-7z"/></svg></button>
        <button id="kb-ash-fwd" aria-label="+10s" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:transparent;border:none;cursor:pointer;"><svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M11.5 4c4 0 7 3 7 7h2.5L17.5 14.5 14 11h2.5c0-2.8-2.2-5-5-5s-5 2.2-5 5 2.2 5 5 5c1.4 0 2.6-.6 3.5-1.5l1.4 1.4C15.2 18 13.4 18.8 11.5 19c-3.9 0-7-3.1-7-7s3.1-7 7-7z"/><text x="11.5" y="13.5" font-size="5.5" font-weight="bold" font-family="sans-serif" fill="white" text-anchor="middle">10</text></svg></button>
        <button id="kb-ash-mute" aria-label="Ton" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:transparent;border:none;cursor:pointer;"><svg id="kb-ash-ic-muted" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5z" stroke="white" stroke-width="2" stroke-linejoin="round"/><line x1="23" y1="9" x2="17" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/><line x1="17" y1="9" x2="23" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/></svg><svg id="kb-ash-ic-unmuted" width="18" height="18" viewBox="0 0 24 24" fill="none" style="display:none"><path d="M11 5L6 9H2v6h4l5 4V5z" stroke="white" stroke-width="2" stroke-linejoin="round"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="white" stroke-width="2" stroke-linecap="round"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></button>
      </div>
    </div>
  </div>
  <div class="kb-ash__content">
    <p style="font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#C0182A;margin:0 0 12px;">&#10024; Exklusiv bei KB ELEMENTS</p>
    <h1 style="font-size:clamp(24px,2.5vw,40px);font-weight:700;line-height:1.08;color:#fff;margin:0 0 12px;letter-spacing:-.02em;">AntiScratch</h1>
    <p style="font-size:13px;line-height:1.6;color:#D6D3D1;margin:0 0 20px;">Unsere AntiScratch-Kochfelder bieten eine besonders widerstandsfähige Glaskeramik-Oberfläche – langlebig, pflegeleicht und ästhetisch überzeugend.</p>
    <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;">
      <li style="display:flex;align-items:flex-start;gap:10px;"><span style="display:flex;align-items:center;justify-content:center;width:24px;height:24px;min-width:24px;background:#C0182A;border-radius:50%;margin-top:1px;"><svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span><div><strong style="font-size:13px;color:#fff;">Kratzfest</strong><br><span style="font-size:11px;color:#A8A29E;">Widerstandsfähige Oberfläche für den täglichen Einsatz</span></div></li>
      <li style="display:flex;align-items:flex-start;gap:10px;"><span style="display:flex;align-items:center;justify-content:center;width:24px;height:24px;min-width:24px;background:#C0182A;border-radius:50%;margin-top:1px;"><svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1L12 3.5V7C12 10 7 13 7 13S2 10 2 7V3.5L7 1Z" stroke="white" stroke-width="1.5" stroke-linejoin="round"/></svg></span><div><strong style="font-size:13px;color:#fff;">Fleckenresistent</strong><br><span style="font-size:11px;color:#A8A29E;">Leicht zu reinigen – auch bei hartnäckigen Verschmutzungen</span></div></li>
      <li style="display:flex;align-items:flex-start;gap:10px;"><span style="display:flex;align-items:center;justify-content:center;width:24px;height:24px;min-width:24px;background:#C0182A;border-radius:50%;margin-top:1px;"><svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1L8.8 5.2L13.4 5.6L10 8.6L11 13.2L7 10.8L3 13.2L4 8.6L0.6 5.6L5.2 5.2Z" stroke="white" stroke-width="1.2" stroke-linejoin="round"/></svg></span><div><strong style="font-size:13px;color:#fff;">Langlebig</strong><br><span style="font-size:11px;color:#A8A29E;">Hochwertige Verarbeitung für jahrelange Freude</span></div></li>
    </ul>
  </div>
</div>
<script>
(function(){
  var video=document.getElementById('kb-ash-video');
  var spinner=document.getElementById('kb-ash-spinner');
  var media=video&&video.closest('.kb-ash__media');
  var btnPlay=document.getElementById('kb-ash-play');
  var btnBack=document.getElementById('kb-ash-back');
  var btnFwd=document.getElementById('kb-ash-fwd');
  var btnMute=document.getElementById('kb-ash-mute');
  var progressBar=document.getElementById('kb-ash-progress-bar');
  var progressFill=document.getElementById('kb-ash-progress-fill');
  var progressThumb=document.getElementById('kb-ash-progress-thumb');
  var timeEl=document.getElementById('kb-ash-time');
  if(!video)return;
  var icPause=document.getElementById('kb-ash-ic-pause');
  var icPlay=document.getElementById('kb-ash-ic-play');
  var icMuted=document.getElementById('kb-ash-ic-muted');
  var icUnmuted=document.getElementById('kb-ash-ic-unmuted');
  var startOffset=22;
  function hideSpinner(){if(spinner)spinner.classList.add('is-hidden');}
  function fmt(s){s=Math.floor(s||0);return Math.floor(s/60)+':'+(s%60<10?'0':'')+(s%60);}
  function updateProgress(){
    if(!video.duration)return;
    var p=(video.currentTime/video.duration)*100;
    if(progressFill)progressFill.style.width=p+'%';
    if(progressThumb)progressThumb.style.left=p+'%';
    if(timeEl)timeEl.textContent=fmt(video.currentTime)+' / '+fmt(video.duration);
  }
  video.addEventListener('canplay',hideSpinner);
  video.addEventListener('playing',hideSpinner);
  video.addEventListener('loadedmetadata',function(){
    if(video.duration>startOffset) video.currentTime=startOffset;
    updateProgress();
  });
  video.addEventListener('timeupdate',updateProgress);
  var dragging=false;
  function seek(e){if(!video.duration)return;var rect=progressBar.getBoundingClientRect();var x=(e.touches?e.touches[0].clientX:e.clientX)-rect.left;video.currentTime=Math.max(0,Math.min(1,x/rect.width))*video.duration;}
  if(progressBar){progressBar.addEventListener('mousedown',function(e){dragging=true;seek(e);});progressBar.addEventListener('touchstart',function(e){dragging=true;seek(e);},{passive:true});document.addEventListener('mousemove',function(e){if(dragging)seek(e);});document.addEventListener('touchmove',function(e){if(dragging)seek(e);},{passive:true});document.addEventListener('mouseup',function(){dragging=false;});document.addEventListener('touchend',function(){dragging=false;});}
  function syncPlay(){if(icPause)icPause.style.display=video.paused?'none':'';if(icPlay)icPlay.style.display=video.paused?'':'none';if(media)media.classList.toggle('kb-ash--paused',video.paused);}
  if(btnPlay)btnPlay.addEventListener('click',function(){if(video.paused){video.loop=true;video.play();}else{video.pause();video.loop=false;}});
  video.addEventListener('play',syncPlay);video.addEventListener('pause',syncPlay);
  if(btnBack)btnBack.addEventListener('click',function(){video.currentTime=Math.max(0,video.currentTime-10);});
  if(btnFwd)btnFwd.addEventListener('click',function(){video.currentTime=Math.min(video.duration||0,video.currentTime+10);});
  if(btnMute)btnMute.addEventListener('click',function(){video.muted=!video.muted;if(icMuted)icMuted.style.display=video.muted?'':'none';if(icUnmuted)icUnmuted.style.display=video.muted?'none':'';});
  var controls=media&&media.querySelector('.kb-ash__controls');
  if(media&&controls){media.addEventListener('mouseenter',function(){controls.style.opacity='1';});media.addEventListener('mouseleave',function(){if(!video.paused)controls.style.opacity='0';});}
})();
</script>
{%- endif -%}

