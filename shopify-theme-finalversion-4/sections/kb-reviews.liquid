<div class="kb-reviews-section page-width">
  <style>
    .kb-reviews-section { max-width: 900px; margin: 0 auto; padding: 8px 24px 48px; }
    @media (max-width: 749px) { .kb-reviews-section { padding: 8px 16px 32px; } }
    .kb-reviews-link-wrap { text-align: center; padding: 32px 0 8px; }
    .kb-reviews-link { display: inline-flex; align-items: center; gap: 8px; padding: 11px 28px; border: 1px solid #1C1917; border-radius: 6px; text-decoration: none; color: #1C1917; font-size: 14px; font-weight: 500; letter-spacing: .02em; transition: border-color .2s, color .2s; }
    .kb-reviews-link:hover { border-color: #C0182A; color: #C0182A; }
    .kb-reviews-link svg { flex-shrink: 0; transition: transform .2s; }
    .kb-reviews-link:hover svg { transform: translateX(3px); }
  </style>
  <div class="kb-reviews-trust-bar">
    <div class="kb-reviews-trust-bar__item">
      <span class="kb-reviews-trust-bar__num">4,9/5</span>
      <span class="kb-reviews-trust-bar__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="kb-reviews-trust-bar__label">Durchschnitt</span>
    </div>
    <div class="kb-reviews-trust-bar__item">
      <span class="kb-reviews-trust-bar__num">2.463</span>
      <span class="kb-reviews-trust-bar__sub">verifiziert</span>
      <span class="kb-reviews-trust-bar__label">Bewertungen</span>
    </div>
    <div class="kb-reviews-trust-bar__item">
      <span class="kb-reviews-trust-bar__num">98%</span>
      <span class="kb-reviews-trust-bar__sub">&nbsp;</span>
      <span class="kb-reviews-trust-bar__label">Empfehlen uns</span>
    </div>
  </div>
  {% content_for 'blocks' %}
  <div class="kb-reviews-link-wrap">
    <a href="/pages/kundenbewertungen" class="kb-reviews-link">
      Alle Bewertungen lesen
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Bewertungen",
  "tag": "div",
  "blocks": [
    { "type": "@app" }
  ],
  "settings": []
}
{% endschema %}
