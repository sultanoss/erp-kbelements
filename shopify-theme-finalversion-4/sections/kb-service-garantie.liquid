<style>
/* ===== HERO ===== */
.kb-sg-header-img{
  width:100vw;
  margin-left:50%;
  transform:translateX(-50%);
  margin-top:-40px;
}
.kb-sg-header-img img{width:100%;height:auto;display:block;}
@media(max-width:749px){
  .kb-sg-header-img{margin-top:0;}
}

/* ===== LAYOUT ===== */
.kb-sg-page{padding:0;font-family:inherit;}
.kb-sg-inner{max-width:1200px;margin:0 auto;padding:0 24px;}
@media(max-width:749px){.kb-sg-inner{padding:0 16px;}}
.kb-sg-sep{width:100vw;margin-left:50%;transform:translateX(-50%);background:#F5F3EF;height:8px;}
.kb-sg-section-title{font-size:22px;font-weight:700;color:#1C1917;margin:0 0 24px;padding-bottom:12px;border-bottom:2px solid #C0182A;display:inline-block;}
@media(max-width:749px){.kb-sg-section-title{font-size:18px;}}

/* ===== TRUST ===== */
.kb-sg-trust-wrap{padding:56px 0;}
@media(max-width:749px){.kb-sg-trust-wrap{padding:36px 0;}}
.kb-sg-trust{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
@media(max-width:600px){.kb-sg-trust{grid-template-columns:1fr;gap:12px;}}
.kb-sg-trust__item{text-align:center;padding:28px 16px;border:1px solid #eee;border-radius:8px;}
@media(max-width:600px){.kb-sg-trust__item{padding:20px 16px;display:flex;align-items:center;gap:16px;text-align:left;}}
.kb-sg-trust__icon{font-size:32px;margin-bottom:10px;color:#C0182A;}
@media(max-width:600px){.kb-sg-trust__icon{margin-bottom:0;flex-shrink:0;}}
.kb-sg-trust__number{font-size:32px;font-weight:800;color:#1C1917;margin-bottom:4px;}
@media(max-width:600px){.kb-sg-trust__number{font-size:24px;}}
.kb-sg-trust__label{font-size:14px;color:#666;}

/* ===== INFO KARTEN ===== */
.kb-sg-info-wrap{padding:56px 0;}
@media(max-width:749px){.kb-sg-info-wrap{padding:36px 0;}}
.kb-sg-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
@media(max-width:900px){.kb-sg-cards{grid-template-columns:repeat(2,1fr);}}
@media(max-width:500px){.kb-sg-cards{grid-template-columns:1fr;}}
.kb-sg-card{
  background:#fff;
  border:1px solid #eee;
  border-radius:10px;
  padding:28px 24px;
  box-shadow:0 2px 8px rgba(0,0,0,.04);
  display:flex;
  flex-direction:column;
  gap:12px;
}
.kb-sg-card__icon{font-size:28px;line-height:1;}
.kb-sg-card__title{font-size:16px;font-weight:700;color:#1C1917;margin:0;}
.kb-sg-card__text{font-size:14px;color:#555;line-height:1.65;margin:0;flex:1;}
.kb-sg-card__link{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:13px;
  font-weight:600;
  color:#C0182A;
  text-decoration:none;
  margin-top:4px;
}
.kb-sg-card__link:hover{text-decoration:underline;}

/* ===== GARANTIE BLOCK ===== */
.kb-sg-guarantee-wrap{padding:56px 0;}
@media(max-width:749px){.kb-sg-guarantee-wrap{padding:36px 0;}}
.kb-sg-guarantee{
  background:#1C1917;
  border-radius:12px;
  padding:48px 40px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:40px;
  align-items:center;
}
@media(max-width:700px){
  .kb-sg-guarantee{grid-template-columns:1fr;padding:32px 24px;gap:24px;}
}
.kb-sg-guarantee__badge{
  display:inline-block;
  background:#C0182A;
  color:#fff;
  font-size:11px;
  font-weight:700;
  letter-spacing:.1em;
  text-transform:uppercase;
  padding:5px 12px;
  border-radius:4px;
  margin-bottom:16px;
}
.kb-sg-guarantee__title{
  font-size:clamp(20px,3vw,36px);
  font-weight:800;
  color:#fff;
  line-height:1.2;
  margin:0 0 16px;
}
.kb-sg-guarantee__text{
  font-size:15px;
  color:#aaa;
  line-height:1.7;
  margin:0;
}
.kb-sg-guarantee__right{
  display:flex;
  flex-direction:column;
  gap:16px;
}
.kb-sg-guarantee__item{
  display:flex;
  align-items:flex-start;
  gap:14px;
  padding:16px;
  background:rgba(255,255,255,.06);
  border-radius:8px;
}
.kb-sg-guarantee__item-icon{
  width:36px;
  height:36px;
  flex-shrink:0;
  background:#C0182A;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fff;
  font-size:16px;
  font-weight:700;
}
.kb-sg-guarantee__item-title{font-size:14px;font-weight:700;color:#fff;margin:0 0 4px;}
.kb-sg-guarantee__item-text{font-size:13px;color:#888;line-height:1.6;margin:0;}

/* ===== KONTAKT ===== */
.kb-sg-contact-wrap{padding:56px 0;}
@media(max-width:749px){.kb-sg-contact-wrap{padding:36px 0;}}
.kb-sg-contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
@media(max-width:700px){.kb-sg-contact-grid{grid-template-columns:1fr;}}
.kb-sg-contact-card{
  background:#F5F3EF;
  border-radius:10px;
  padding:28px 24px;
  display:flex;
  flex-direction:column;
  gap:10px;
}
.kb-sg-contact-card__icon{font-size:28px;}
.kb-sg-contact-card__title{font-size:16px;font-weight:700;color:#1C1917;margin:0;}
.kb-sg-contact-card__text{font-size:14px;color:#555;line-height:1.65;margin:0;}
.kb-sg-contact-card__cta{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:#C0182A;
  color:#fff !important;
  padding:10px 20px;
  border-radius:6px;
  text-decoration:none;
  font-size:14px;
  font-weight:600;
  margin-top:4px;
  align-self:flex-start;
  transition:background .2s;
}
@media(max-width:500px){.kb-sg-contact-card__cta{width:100%;justify-content:center;}}
.kb-sg-contact-card__cta:hover{background:#a01020;}

/* ===== ABLAUF ===== */
.kb-sg-steps-wrap{padding:56px 0;}
@media(max-width:749px){.kb-sg-steps-wrap{padding:36px 0;}}
.kb-sg-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;}
@media(max-width:700px){.kb-sg-steps{grid-template-columns:1fr 1fr;gap:16px;}}
@media(max-width:400px){.kb-sg-steps{grid-template-columns:1fr;}}
.kb-sg-step{text-align:center;padding:0 16px;position:relative;}
.kb-sg-step:not(:last-child)::after{content:'';position:absolute;top:22px;right:-1px;width:2px;height:44px;background:#eee;}
@media(max-width:700px){.kb-sg-step:not(:last-child)::after{display:none;}}
.kb-sg-step__num{width:44px;height:44px;border-radius:50%;background:#C0182A;color:#fff;font-size:18px;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;}
.kb-sg-step__title{font-size:14px;font-weight:700;color:#1C1917;margin:0 0 8px;}
.kb-sg-step__text{font-size:13px;color:#666;line-height:1.6;margin:0;}

/* ===== CTA ===== */
.kb-sg-cta-wrap{padding:56px 0;text-align:center;}
@media(max-width:749px){.kb-sg-cta-wrap{padding:36px 0;}}
.kb-sg-cta-title{font-size:24px;font-weight:800;color:#1C1917;margin-bottom:10px;}
@media(max-width:749px){.kb-sg-cta-title{font-size:20px;}}
.kb-sg-cta-sub{font-size:17px;color:#444;font-weight:500;margin-bottom:28px;}
@media(max-width:749px){.kb-sg-cta-sub{font-size:15px;}}
.kb-sg-cta-sub strong{color:#C0182A;font-weight:700;}
.kb-sg-categories{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;}
.kb-sg-categories a{display:inline-flex;align-items:center;gap:8px;color:#333 !important;padding:10px 18px;border-radius:6px;text-decoration:none;font-weight:500;font-size:13.5px;border:1px solid #ddd;background:#F5F3EF;transition:all .2s;white-space:nowrap;}
.kb-sg-categories a:hover{border-color:#C0182A;color:#C0182A !important;background:#fff;}
.kb-sg-arrow{font-size:14px;color:#999;transition:color .2s,transform .2s;}
.kb-sg-categories a:hover .kb-sg-arrow{color:#C0182A;transform:translateX(2px);}
</style>

